.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
.idea/
*.iml
.DS_Store
/out/
/bin/
.claude/

# Env / secrets (never commit real credentials — compose/yaml use ${VAR:dev-default})
.env
.env.local
.env.*.local
*.env

# Images / scratch artifacts (screenshots like the former example.png are not load-bearing)
*.png
*.jpg
*.jpeg
*.gif
# keep load-bearing doc assets explicitly:
!docs/**/*.png
!docs/**/*.jpg
!docs/**/*.gif

# Logs
*.log
*.log.gz

# BANK-13 load-benchmark artifacts: keep the harness + the distilled BENCHMARKS.md numbers, never the
# bulky Gatling HTML reports / raw simulation.log (regenerated by `gatlingRun`; also under build/).
examples/acme-bank/benchmarks/results/
**/simulation.log
